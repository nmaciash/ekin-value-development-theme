# ============================================================
# .env.example — Plantilla de variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# --- ACF (Advanced Custom Fields) ---------------------------
# Muestra u oculta el menú de ACF en el panel de WordPress.
# true  → visible (desarrollo / administrador único)
# false → oculto  (producción / cliente con acceso al admin)
ACF_SHOW_ADMIN=true

# --- Google Maps --------------------------------------------
# Necesaria si usas bloques o shortcodes con mapas integrados.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Entorno ------------------------------------------------
# Útil para activar/desactivar logs o comportamientos de debug.
# Valores: development | staging | production
ENVIRONMENT=development

# --- Correo (SMTP) ------------------------------------------
# Solo si usas WP Mail SMTP u otro plugin de correo con PHP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password_here

# --- APIs externas (ejemplos) --------------------------------
# RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
# RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
# MAILCHIMP_API_KEY=your_mailchimp_api_key_here
